{
  "manifest_version": 3,
  "name": "P2P CMS",
  "version": "1.0.0",
  "description": "Manage and share your content across devices on your local network",
  "permissions": ["storage"],
  "host_permissions": ["http://127.0.0.1:41235/*", "http://localhost:41235/*"],
  "action": {
    "default_popup": "popup/popup.html"
  },
  "background": {
    "scripts": ["background.js"],
    "type": "module"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "p2p-cms@local",
      "strict_min_version": "109.0"
    }
  }
}
